# Rewrite tarball host in lockfile to whichever registry is currently configured.
# Lets local devs use a mirror (e.g. registry.npmjs.org) while CI uses registry.npmjs.org,
# without churning pnpm-lock.yaml.
replace-registry-host=always

# Don't bake tarball URLs into the lockfile going forward.
# Integrity (sha512) still guarantees content.
lockfile-include-tarball-url=false
